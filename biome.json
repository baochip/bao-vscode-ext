{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"files": {
		"includes": [
			"**/*",
			"!node_modules",
			"!out",
			"!dist",
			"!coverage",
			"!*.vsix",
			"!.vscode-test",
			"!src/test/fixtures/workspace",
			"!**/*.svg"
		]
	},
	"formatter": {
		"indentWidth": 2,
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"style": {
				"useImportType": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single"
		}
	}
}
