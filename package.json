{
	"name": "bao-vscode-ext",
	"displayName": "%ext.displayName%",
	"description": "%ext.description%",
	"publisher": "baochip",
	"website": "https://baochip.com",
	"version": "1.0.0",
	"icon": "media/baochip-128x128-logo-only.png",
	"license": "Apache-2.0",
	"pricing": "Free",
	"repository": {
		"type": "git",
		"url": "https://github.com/baochip/bao-vscode-ext.git"
	},
	"engines": {
		"vscode": "^1.106.1"
	},
	"l10n": "./l10n",
	"categories": [
		"Programming Languages",
		"Debuggers",
		"Other"
	],
	"keywords": [
		"baochip",
		"precursor",
		"xous",
		"xous-core",
		"embedded",
		"development",
		"microcontroller"
	],
	"activationEvents": [
		"onStartupFinished"
	],
	"contributes": {
		"commands": [
			{
				"command": "baochip.openWelcome",
				"title": "%cmd.openWelcome%"
			},
			{
				"command": "baochip.openSettings",
				"title": "%cmd.openSettings%"
			},
			{
				"command": "baochip.setBootloaderSerialPort",
				"title": "%cmd.setBootPort%"
			},
			{
				"command": "baochip.setRunSerialPort",
				"title": "%cmd.setRunPort%"
			},
			{
				"command": "baochip.setMonitorDefaultPort",
				"title": "%cmd.setMonitorDefaultPort%"
			},
			{
				"command": "baochip.setMonitorBaud",
				"title": "%cmd.setMonitorBaud%"
			},
			{
				"command": "baochip.openMonitor",
				"title": "%cmd.monitorOpen%"
			},
			{
				"command": "baochip.stopMonitor",
				"title": "%cmd.monitorStop%"
			},
			{
				"command": "baochip.setFlashLocation",
				"title": "%cmd.setFlashLocation%"
			},
			{
				"command": "baochip.selectBuildTarget",
				"title": "%cmd.selectBuildTarget%"
			},
			{
				"command": "baochip.setBuildMode",
				"title": "%cmd.setBuildMode%"
			},
			{
				"command": "baochip.clean",
				"title": "%cmd.clean%"
			},
			{
				"command": "baochip.build",
				"title": "%cmd.build%"
			},
			{
				"command": "baochip.selectApp",
				"title": "%cmd.selectApp%"
			},
			{
				"command": "baochip.createApp",
				"title": "%cmd.createApp%"
			},
			{
				"command": "baochip.flash",
				"title": "%cmd.flash%"
			},
			{
				"command": "baochip.buildFlashMonitor",
				"title": "%cmd.buildFlashMonitor%"
			},
			{
				"command": "baochip.resetUvSetup",
				"title": "%cmd.resetUvSetup%"
			},
			{
				"command": "baochip.rerunSetup",
				"title": "%cmd.rerunSetup%"
			}
		],
		"menus": {},
		"configuration": [
			{
				"title": "%cfg.title.general%",
				"properties": {
					"baochip.showWelcomeOnStartup": {
						"type": "boolean",
						"default": true,
						"scope": "application",
						"description": "%cfg.general.showWelcomeOnStartup%",
						"order": 1
					},
					"baochip.reRunExtensionSetup": {
						"type": "null",
						"markdownDescription": "%cfg.general.rerunSetup%",
						"order": 2
					}
				}
			},
			{
				"title": "%cfg.title.ports%",
				"scope": "resource",
				"properties": {
					"baochip.serialPortBootloader": {
						"type": "string",
						"default": "",
						"description": "%cfg.ports.bootloader%",
						"order": 1
					},
					"baochip.serialPortRun": {
						"type": "string",
						"default": "",
						"description": "%cfg.ports.run%",
						"order": 2
					},
					"baochip.monitorDefaultPort": {
						"type": "string",
						"enum": [
							"run",
							"bootloader"
						],
						"default": "run",
						"description": "%cfg.ports.monitorDefault%",
						"order": 3
					}
				}
			},
			{
				"title": "%cfg.title.monitor%",
				"scope": "resource",
				"properties": {
					"baochip.monitor.defaultBaud": {
						"type": "integer",
						"default": 1000000,
						"minimum": 1,
						"description": "%cfg.monitor.defaultBaud%",
						"order": 1
					},
					"baochip.monitor.crlf": {
						"type": "boolean",
						"default": true,
						"description": "%cfg.monitor.crlf%",
						"order": 2
					},
					"baochip.monitor.raw": {
						"type": "boolean",
						"default": true,
						"description": "%cfg.monitor.raw%",
						"order": 3
					},
					"baochip.monitor.echo": {
						"type": "boolean",
						"default": false,
						"description": "%cfg.monitor.echo%",
						"order": 4
					}
				}
			},
			{
				"title": "%cfg.title.build%",
				"scope": "resource",
				"properties": {
					"baochip.buildMode": {
						"type": "string",
						"enum": [
							"auto",
							"xous-core",
							"out-of-tree"
						],
						"default": "auto",
						"description": "%cfg.build.buildMode%",
						"order": 0
					},
					"baochip.buildTarget": {
						"type": "string",
						"default": "",
						"description": "%cfg.build.target%",
						"order": 1
					}
				}
			},
			{
				"title": "%cfg.title.flashing%",
				"scope": "resource",
				"properties": {
					"baochip.flashLocation": {
						"type": "string",
						"default": "",
						"description": "%cfg.flashing.location%",
						"order": 1
					}
				}
			},
			{
				"title": "%cfg.title.intree%",
				"scope": "resource",
				"properties": {
					"baochip.xousCorePath": {
						"type": "string",
						"default": "",
						"description": "%cfg.intree.xousCorePath%",
						"order": 1
					},
					"baochip.xousAppName": {
						"type": "string",
						"default": "",
						"description": "%cfg.intree.appName%",
						"order": 2
					}
				}
			},
			{
				"title": "%cfg.title.outOfTree%",
				"scope": "resource",
				"properties": {
					"baochip.outOfTree.kernelMode": {
						"type": "string",
						"enum": [
							"ask",
							"ci-sync",
							"manual"
						],
						"default": "ask",
						"description": "%cfg.outOfTree.kernelMode%",
						"order": 1
					},
					"baochip.outOfTree.kernelFilesPath": {
						"type": "string",
						"default": "",
						"description": "%cfg.outOfTree.kernelFilesPath%",
						"order": 2
					},
					"baochip.outOfTree.extraFeatures": {
						"type": "array",
						"items": {
							"type": "string"
						},
						"default": [],
						"description": "%cfg.outOfTree.extraFeatures%",
						"order": 3
					}
				}
			}
		],
		"viewsContainers": {
			"activitybar": [
				{
					"id": "bao-container",
					"title": "%views.container.title%",
					"icon": "media/bao-icon.svg"
				}
			]
		},
		"views": {
			"bao-container": [
				{
					"id": "bao-view",
					"name": "%views.main%"
				},
				{
					"id": "bao-docs",
					"name": "%views.docs%"
				}
			]
		},
		"keybindings": [
			{
				"command": "baochip.build",
				"key": "ctrl+alt+b"
			},
			{
				"command": "baochip.flash",
				"key": "ctrl+alt+f"
			},
			{
				"command": "baochip.buildFlashMonitor",
				"key": "ctrl+alt+shift+b"
			}
		]
	},
	"main": "./out/extension.js",
	"scripts": {
		"clean": "node -e \"fs.rmSync('out',{recursive:true,force:true})\"",
		"clean:test": "node -e \"fs.rmSync('out/test',{recursive:true,force:true})\"",
		"compile": "tsc -p . && tsc-alias -p tsconfig.json",
		"watch": "tsc -w -p .",
		"vscode:prepublish": "npm run clean && npm run compile",
		"package": "npx vsce package",
		"lint": "biome check .",
		"lint:fix": "biome check --write --unsafe .",
		"format": "biome format --write .",
		"test": "tsx --test \"src/test/unit/**/*.test.ts\"",
		"test:integration": "npm run compile && npm run clean:test && tsc -p tsconfig.test.json && tsc-alias -p tsconfig.test.json && vscode-test",
		"test:python": "uv run --with pytest --with tomlkit --with pyserial pytest resources/tools-bao/tests"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "^24.13.2",
		"@types/sinon": "^21.0.1",
		"@types/vscode": "~1.106.1",
		"@vscode/test-cli": "^0.0.15",
		"@vscode/test-electron": "^3.0.0",
		"@vscode/vsce": "^3.9.2",
		"mocha": "^11.7.6",
		"sinon": "^22.0.0",
		"tsc-alias": "^1.8.17",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@vscode/codicons": "^0.0.45"
	},
	"overrides": {
		"diff": "8.0.4",
		"serialize-javascript": "7.0.6"
	}
}
