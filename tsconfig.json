{
	"compilerOptions": {
		"module": "commonjs",
		"target": "ES2020",
		"outDir": "out",
		"rootDir": "src",
		"strict": true,
		"sourceMap": true,
		"lib": ["ES2020"],
		"types": ["node"],
		"paths": {
			"@constants": ["./src/constants"],
			"@commands/*": ["./src/commands/*"],
			"@services/*": ["./src/services/*"],
			"@views/*": ["./src/views/*"],
			"@tree/*": ["./src/views/tree/*"],
			"@webviews/*": ["./src/views/webviews/*"],
			"@util/*": ["./src/util/*"]
		}
	},
	"exclude": ["node_modules", ".vscode-test", "src/**/*.test.ts"]
}
